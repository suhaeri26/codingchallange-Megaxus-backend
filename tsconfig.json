{
  "compilerOptions": {
    /* 📁 Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* ⚙️ Environment */
    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    /* 🔥 Module Resolution */
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* 🧠 Type Safety */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* 🧪 Dev Experience */
    "sourceMap": true,

    /* 🚀 Build Optimization */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}